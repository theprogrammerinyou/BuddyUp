# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── App API ──────────────────────────────────────────────────────────────────
# Backend URL used at runtime in the app.
# For local dev: http://localhost:8080/api/v1
# For sharing the APK: use your machine's LAN IP, e.g. http://192.168.1.x:8080/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Public token from https://account.mapbox.com/access-tokens/
# Used at runtime to load map tiles.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.XXXXXXXXXX

# Secret token (starts with sk.) — used ONLY during EAS Build to download Mapbox SDK.
# Set this in EAS Build secrets: https://expo.dev/accounts/[account]/projects/[slug]/secrets
# Do NOT put sk. tokens in .env or commit them.
# MAPBOX_SECRET_TOKEN=sk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.XXXXXXXXXX
